
# ============================================
# BazZ Platform — Global .gitignore
# ============================================

# ---- Node.js ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/

# ---- Build Outputs ----
dist/
build/
out/
.next/
.nuxt/

# ---- Environment Files ----
.env
.env.local
.env.development
.env.staging
.env.production
.env.test
!.env.example
!.env.*.example

# ---- IDE & Editors ----
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
.DS_Store
Thumbs.db

# ---- Flutter / Dart ----
apps/merchant-app/.dart_tool/
apps/merchant-app/.flutter-plugins
apps/merchant-app/.flutter-plugins-dependencies
apps/merchant-app/.packages
apps/merchant-app/.metadata
apps/merchant-app/pubspec.lock
apps/merchant-app/build/
apps/merchant-app/ios/Pods/
apps/merchant-app/ios/.symlinks/
apps/merchant-app/android/.gradle/
apps/merchant-app/android/.kotlin/
apps/merchant-app/android/local.properties
apps/merchant-app/android/captures/
apps/merchant-app/*.iml
apps/merchant-app/*.g.dart
apps/merchant-app/**/*.g.dart
apps/merchant-app/**/*.freezed.dart
apps/merchant-app/**/*.mocks.dart
apps/merchant-app/coverage/
# Non-mobile Flutter platform scaffolds (BazZ is mobile-only)
apps/merchant-app/linux/
apps/merchant-app/macos/
apps/merchant-app/web/
apps/merchant-app/windows/
# Figma export (design reference only, not production code)
docs/design/figma-export/

# ---- Prisma ----
apps/api/prisma/migrations/dev/
apps/api/generated/

# ---- Cowork / Claude ----
.claude/

# ---- Stray root-level files (safe to delete manually) ----
/login_form_screen.dart
/main.dart

# ---- Docker ----
.docker/
docker-compose.override.yml

# ---- Testing ----
coverage/
.nyc_output/
test-results/
playwright-report/

# ---- Logs ----
logs/
*.log
lerna-debug.log*

# ---- Firebase ----
.firebase/
firebase-debug.log
.firebaserc
# Keep google-services.json structure but not actual keys
apps/merchant-app/android/app/google-services.json
apps/merchant-app/ios/Runner/GoogleService-Info.plist

# ---- Certificates & Keys ----
*.pem
*.key
*.cert
*.p12
*.jks
*.keystore

# ---- Firebase Service Account (NEVER commit — add to Railway env vars) ----
*firebase-adminsdk*.json
*service-account*.json

# ---- Cache ----
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache

# ---- OS Generated ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---- Temporary ----
tmp/
temp/
*.tmp
*.temp
